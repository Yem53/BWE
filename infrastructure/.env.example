# ============================================================================
# BWE infrastructure .env template
# Copy to ~/.hermes/.env (Mac) or %USERPROFILE%\.hermes\.env (Windows)
# Fill in YOUR secrets. NEVER commit a real .env to git.
# ============================================================================

# === Binance keys (only if doing testnet/live trading; not needed for collectors) ===
BINANCE_API_KEY=<your_binance_main_api_key>
BINANCE_API_SECRET=<your_binance_main_api_secret>

# === Binance testnet (for paper-LIVE testnet orders) ===
BINANCE_TESTNET_API_KEY=<your_testnet_api_key>
BINANCE_TESTNET_SECRET=<your_testnet_api_secret>

# === OKX (for OKX trading or research; not needed for liquidation collector) ===
OKX_API_KEY=<your_okx_key>
OKX_API_SECRET=<your_okx_secret>
OKX_PASSPHRASE=<your_okx_passphrase>
OKX_NOTIFY_CHAT_ID=<your_telegram_chat_id>
OKX_SCAN_CHAT_ID=<your_telegram_chat_id>

# === Telegram bots (BWE matrix monitor + paper-LIVE notifications) ===
BWE_TRADE_TEST_BOT_TOKEN=<your_telegram_bot_token>
BWE_TRADE_TEST_CHAT_ID=<your_telegram_chat_id>
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>
TELEGRAM_CHAT_ID=<your_telegram_chat_id>

# === Telegram channels listened (BWE matrix monitor) ===
# These are public BWE channels — IDs not secret but needed
BWE_CHANNELS=BWE_OI_Price_monitor,BWE_pricechange_monitor,BWE_Reserved6,...

# === Proxy (required from US for binance fapi REST) ===
# Mac with clashverge: http://127.0.0.1:7897 (mixed mode)
# Windows with v2rayN/clashverge: same port if you replicate
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# === Anthropic Claude (for LLM debate rounds) ===
ANTHROPIC_API_KEY=<your_anthropic_key>
